# --- Proveedor del LLM -----------------------------------------------------
# Elige "google" (por defecto) u "openai". El código ajusta automáticamente
# los modelos y la dimensión de embeddings al proveedor elegido.
LLM_PROVIDER=google

# --- Claves de API ---------------------------------------------------------
# Solo necesitas la clave del proveedor que hayas seleccionado en LLM_PROVIDER.
# Puedes dejar la otra vacía (o rellenar ambas y cambiar solo LLM_PROVIDER).

# Google Gemini -> https://aistudio.google.com/apikey
GOOGLE_API_KEY= AIzaSyBtqx5sh1gtOLtgQS6A5TAXEFO0ilLQzv4

# OpenAI -> https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-clave-aqui

# (Open-Meteo, usado por get_weather, NO requiere clave.)
