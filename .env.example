# --- Proveedor del LLM -----------------------------------------------------
# Elige "google" (por defecto) u "openai". El código ajusta automáticamente
# los modelos y la dimensión de embeddings al proveedor elegido.
LLM_PROVIDER=google

# --- Claves de API ---------------------------------------------------------

# Google Gemini -> https://aistudio.google.com/apikey
GOOGLE_API_KEY= AI-tu-clave-aqui
# OpenAI -> https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-clave-aqui

# (Open-Meteo, usado por get_weather, NO requiere clave.)
